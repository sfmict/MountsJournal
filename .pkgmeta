package-as: MountsJournal

externals:
	MountsJournal/libs/LibStub: https://repos.curseforge.com/wow/libstub/trunk
	MountsJournal/libs/LibThingsLoad:
		site: https://www.curseforge.com/wow/addons/libthingsload
		url: https://github.com/sfmict/LibThingsLoad
		tag: latest
	MountsJournal/libs/CallbackHandler-1.0: https://repos.curseforge.com/wow/callbackhandler/trunk/CallbackHandler-1.0
	MountsJournal/libs/AceComm-3.0: https://repos.curseforge.com/wow/ace3/trunk/AceComm-3.0
	MountsJournalUI/libs/LibSFDropDown:
		site: https://www.curseforge.com/wow/addons/libsfdropdown
		url: https://github.com/sfmict/LibSFDropDown
		tag: latest

enable-nolib-creation: no

ignore:
	- .*\.md$
	- _config\.yml
	- _test\.lua
	- libs/.*\.toc$
	- libs/LibStub/tests

move-folders:
	MountsJournal/MountsJournal: MountsJournal
	MountsJournal/MountsJournalUI: MountsJournalUI